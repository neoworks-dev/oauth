PORT=8080
KEY_PATH=../api/keys/auth.pem
REDIS_URL=localhost:6379
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_USER=root
SURREAL_PASS=root
DEBUG=true

# SMTP — transactional email (signup verification + password reset codes).
# When unset, email degrades to a no-op that logs each message, so signup/reset
# work in dev (DEBUG=true also echoes the code back in API responses).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=NeoWorks <no-reply@neoworks.io>
